# Closed unit box [-1,1]^3 — single instance "box".
mtllib box.mtl

v -1 -1 -1
v  1 -1 -1
v  1  1 -1
v -1  1 -1
v -1 -1  1
v  1 -1  1
v  1  1  1
v -1  1  1

g box
usemtl wall
# floor  (y = -1)
f 1 2 6
f 1 6 5
# ceiling (y = +1)
f 4 8 7
f 4 7 3
# back   (z = -1)
f 1 4 3
f 1 3 2
# front  (z = +1)
f 5 6 7
f 5 7 8
# left   (x = -1)
f 1 5 8
f 1 8 4
# right  (x = +1)
f 2 3 7
f 2 7 6
