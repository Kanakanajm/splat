# Closed box [-5,5]^3 — single instance "box".
# Large enough that sigma_s=3 (mfp=0.33) never reaches the walls at low bounce depths.
mtllib box.mtl

v -5 -5 -5
v  5 -5 -5
v  5  5 -5
v -5  5 -5
v -5 -5  5
v  5 -5  5
v  5  5  5
v -5  5  5

g box
usemtl wall
# floor  (y = -5)
f 1 2 6
f 1 6 5
# ceiling (y = +5)
f 4 8 7
f 4 7 3
# back   (z = -5)
f 1 4 3
f 1 3 2
# front  (z = +5)
f 5 6 7
f 5 7 8
# left   (x = -5)
f 1 5 8
f 1 8 4
# right  (x = +5)
f 2 3 7
f 2 7 6
